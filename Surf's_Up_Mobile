
<!DOCTYPE html>
<html>
<head>
<title>Surfs Up Trading Book</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
  margin: 0;
  font-family: Arial;
  background: #0f172a;
  color: white;
  overflow: hidden;
}

.book {
  display: flex;
  width: 500%;
  height: 100vh;
  transition: transform 0.5s ease;
}

.page {
  width: 100vw;
  height: 100vh;
  padding: 20px;
  box-sizing: border-box;
}

h1 { font-size: 28px; }

.card {
  background: #1e293b;
  padding: 15px;
  margin: 10px 0;
  border-radius: 10px;
}

.nav {
  position: fixed;
  bottom: 20px;
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 0 20px;
}

button {
  background: #3b82f6;
  border: none;
  padding: 10px 15px;
  color: white;
  border-radius: 8px;
}

input {
  width: 100%;
  padding: 8px;
  margin: 5px 0;
  border-radius: 5px;
  border: none;
}
</style>
</head>

<body>

<div class="book" id="book">

<!-- PAGE 1 -->
<div class="page">
<h1>🏄 Surfs Up Thesis</h1>
<div class="card">Market moves like waves.</div>
<div class="card">Trends build, peak, and break.</div>
</div>

<!-- PAGE 2 -->
<div class="page">
<h1>🌊 Trend Concept</h1>
<div class="card">Ride momentum, don’t fight it.</div>
<div class="card">Wait for confirmation before entry.</div>
</div>

<!-- PAGE 3 -->
<div class="page">
<h1>📊 Trade Journal</h1>

<input id="ticker" placeholder="Ticker (AAPL)">
<input id="entry" placeholder="Entry Price">
<input id="exit" placeholder="Exit Price">
<button onclick="addTrade()">Add Trade</button>

<div id="trades"></div>
</div>

<!-- PAGE 4 -->
<div class="page">
<h1>📈 Stats</h1>
<div id="stats"></div>
</div>

<!-- PAGE 5 -->
<div class="page">
<h1>🧠 Notes</h1>
<div class="card">Discipline > Emotion</div>
<div class="card">Wait for clean setups</div>
</div>

</div>

<div class="nav">
<button onclick="prev()">⬅</button>
<button onclick="next()">➡</button>
</div>

<script>
let page = 0;

function updateBook() {
  document.getElementById("book").style.transform =
    "translateX(-" + (page * 100) + "vw)";
}

function next() {
  if (page < 4) {
    page++;
    updateBook();
  }
}

function prev() {
  if (page > 0) {
    page--;
    updateBook();
  }
}

let trades = JSON.parse(localStorage.getItem("trades")) || [];

function addTrade() {
  let ticker = document.getElementById("ticker").value;
  let entry = parseFloat(document.getElementById("entry").value);
  let exit = parseFloat(document.getElementById("exit").value);

  if (!ticker || !entry || !exit) return;

  let pnl = exit - entry;
  trades.unshift({ ticker, entry, exit, pnl });

  localStorage.setItem("trades", JSON.stringify(trades));
  renderTrades();
}

function renderTrades() {
  let html = "";
  trades.forEach(t => {
    html += `<div class="card">${t.ticker}: $${t.pnl.toFixed(2)}</div>`;
  });
  document.getElementById("trades").innerHTML = html;

  let total = trades.length;
  let wins = trades.filter(t => t.pnl > 0).length;
  let pnl = trades.reduce((a,b)=>a+b.pnl,0);

  let winRate = total ? Math.round((wins/total)*100) : 0;

  document.getElementById("stats").innerHTML =
    `<div class="card">Trades: ${total}</div>
     <div class="card">Win Rate: ${winRate}%</div>
     <div class="card">Total PnL: $${pnl.toFixed(2)}</div>`;
}

renderTrades();
</script>

</body>
</html>